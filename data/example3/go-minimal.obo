format-version: 1.2
default-namespace: idp_ontology
ontology: IDPO


[Term]
id: GO:0000001
name: disorder function
namespace: disorder_function
def: "The function of an IDP/IDR. Includes both active functions, i.e. performed on other proteins, and self-functions."

[Term]
id: GO:0000002
name: entropic chain
namespace: disorder_function
def: "Functions directly associated with the disordered state of proteins that stem from their ability to shift between conformational states without becoming structured. Includes entropic bristles, clocks and springs."
is_a: GO:0000001